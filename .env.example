# GardenApp — Environment Variables
#
# Copy this file to .env (gitignored) and fill in every value.
# On Unraid with Compose Manager, paste these into the "Environment" tab
# or keep the .env file in the same directory as docker-compose.yml.
# NEVER commit the real .env to git.
#
# ──────────────────────────────────────────────────────────────

# ── Your domain ───────────────────────────────────────────────
# The public URL where the app is served (no trailing slash)
FRONTEND_URL=https://garden.yourdomain.com

# ── Database ──────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_use_openssl_rand

# ── Google OAuth ──────────────────────────────────────────────
# See Step 1 of the setup guide for how to get these values.
# Redirect URI to register in Google Console: https://garden.yourdomain.com/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Bootstrap admin ───────────────────────────────────────────
# Your Gmail address. Gets IsAdmin=true automatically on first login.
# Remove this line (or set to empty) after your first login.
BOOTSTRAP_ADMIN_EMAIL=you@gmail.com

# ── Access whitelist ──────────────────────────────────────────
# These accounts bypass the paid-tier check entirely.
# Use for: yourself (even as admin), dedicated testers, beta users.
# IsAdmin users are always allowed regardless — this list is for non-admin free-pass accounts.
# Leave slots blank if unused — empty values are ignored.
ALLOWED_EMAIL_0=you@gmail.com
ALLOWED_EMAIL_1=tester1@gmail.com
ALLOWED_EMAIL_2=tester2@gmail.com

# ── pgAdmin (Postgres GUI — LAN only) ─────────────────────────
# Access at http://your-unraid-ip:5050 from your local network.
# Never expose this to the internet.
PGADMIN_EMAIL=admin@mylivinggarden.local
PGADMIN_PASSWORD=CHANGE_ME_strong_password
