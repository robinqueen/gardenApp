{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=gardenapp.db"
  },
  "DatabaseProvider": "SQLite",
  "Auth": {
    "Enabled": false,
    "RsaKeyPath": "/var/gardenapp/keys/rsa.pem",
    "Issuer": "gardenapp",
    "Audience": "gardenapp-api",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "FrontendUrl": "http://localhost:5173",
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:4173"
    ],
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
