# Dependencies
node_modules/
client/node_modules/

# Build outputs
client/dist/
api/dist/
api/bin/
api/obj/

# Environment files (secrets — never commit)
.env
.env.local
.env.production
.env.*.local
# .env.example is safe to commit — it has no real secrets

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
*.log
npm-debug.log*

# IDE / Editor
.vscode/
.idea/
*.code-workspace
.vs/

# Claude Code
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Personal notes (private, never commit)
NOTES.md

# Secrets / certs
*.pem
*.key
*.crt
.npmrc

# RSA key directory (generated at runtime, never commit)
api/keys/

# .NET local dev config (may contain local dev paths)
api/appsettings.Development.json
# appsettings.Production.json is committed — it has no secrets (secrets come from env vars)