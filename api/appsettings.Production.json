{
  "DatabaseProvider": "PostgreSQL",
  "Auth": {
    "Enabled": true,
    "RsaKeyPath": "/var/gardenapp/keys/rsa.pem",
    "Issuer": "gardenapp",
    "Audience": "gardenapp-api",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "FrontendUrl": "https://mylivinggarden.com",
    "AllowedOrigins": [
      "https://mylivinggarden.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
